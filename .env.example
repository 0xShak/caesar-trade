# ============================================================================
# Caesar Terminal — environment template.  Copy to .env and fill in.
# .env is gitignored. NEVER commit real secrets/keys.
# Validated at boot by @caesar/config (Zod).
# ============================================================================

NODE_ENV=development

# --- Infra (docker-compose defaults) ----------------------------------------
# Host ports are remapped off defaults (biggie already uses 5432/6379).
DATABASE_URL=postgres://caesar:caesar@localhost:55432/caesar
REDIS_URL=redis://localhost:56379
TEMPORAL_ADDRESS=localhost:57233

# --- Privy (Spike C — PROVIDED) ---------------------------------------------
# From your Privy dashboard (app id + secret). Used for login + server-side
# verification of BOTH the access token and the identity (privy-id-token).
PRIVY_APP_ID=
PRIVY_APP_SECRET=
# Exposed to the web client (Vite) — app id only, never the secret.
VITE_PRIVY_APP_ID=

# --- Polygon / Polymarket (Spike A) -----------------------------------------
POLYGON_RPC_HTTP=https://polygon-rpc.com
AMOY_RPC_HTTP=https://rpc-amoy.polygon.technology
# Throwaway Amoy test EOA (generated by the spike if blank). NEVER a real key.
AMOY_PRIVATE_KEY=
POLYMARKET_CLOB_URL=https://clob.polymarket.com

# --- Kalshi (Spike B — DEFERRED until you provision demo creds) --------------
# Create at demo-api.kalshi.co: API key id + downloaded RSA private key (PEM).
KALSHI_API_BASE=https://demo-api.kalshi.co
KALSHI_API_KEY_ID=
# Path to the PEM file (kept out of git). Do NOT paste the key inline.
KALSHI_PRIVATE_KEY_PEM=./secrets/kalshi-demo.pem
